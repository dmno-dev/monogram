{
  "contributes": {
    "languages": [
      {
        "id": "vue",
        "extensions": [
          ".vue"
        ],
        "configuration": "./vue.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vue",
        "scopeName": "text.html.vue",
        "path": "./vue.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.derivative": "html",
          "source.js": "javascript",
          "source.ts": "typescript",
          "source.tsx": "typescriptreact",
          "source.js.jsx": "javascriptreact",
          "source.css": "css",
          "source.css.scss": "scss",
          "source.css.less": "less",
          "source.stylus": "stylus",
          "source.postcss": "postcss",
          "source.ts.embedded.html.vue": "typescript"
        }
      },
      {
        "scopeName": "vue.interpolations",
        "path": "./vue.interpolations.tmLanguage.json",
        "injectTo": [
          "text.html.vue",
          "text.html.markdown",
          "text.html.derivative",
          "text.pug"
        ]
      },
      {
        "scopeName": "vue.directives",
        "path": "./vue.directives.tmLanguage.json",
        "injectTo": [
          "text.html.vue",
          "text.html.markdown",
          "text.html.derivative",
          "text.pug"
        ]
      }
    ]
  }
}
